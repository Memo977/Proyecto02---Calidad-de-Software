# ──────────────────────────────────────────────────────────────────────────────
# .env.example
# Plantilla de variables de entorno para el backend de SecureApp.
# Copia este archivo a .env y completa los valores con los tuyos:
#
#   cp .env.example .env
#
# ⚠️  NUNCA subas tu archivo .env real al repositorio.
#     Este archivo (.env.example) SÍ se puede versionar porque no contiene
#     valores reales — solo sirve como guía para otros desarrolladores.
# ──────────────────────────────────────────────────────────────────────────────

# ── Base de datos PostgreSQL ──────────────────────────────────────────────────
# Formato: postgresql://<usuario>:<password>@<host>:<puerto>/<nombre_db>
# Cambia TU_PASSWORD por la contraseña real de tu instancia local de PostgreSQL.
DATABASE_URL="postgresql://postgres:TU_PASSWORD@localhost:5432/proyecto2_db"

# ── Seguridad — JWT y Cookies ─────────────────────────────────────────────────
# Mínimo 32 caracteres. Usa una cadena aleatoria larga en producción.
# Puedes generar una con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="CHANGE_THIS_SECRET_MIN_32_CHARACTERS_XXXXXXXXXXXXXXX"
COOKIE_SECRET="CHANGE_THIS_COOKIE_SECRET_MIN_32_CHARS_XXXXXXXXXX"

# ── Entorno de ejecución ──────────────────────────────────────────────────────
# Usa "development" en local y "production" en el servidor/Docker.
NODE_ENV="development"

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=4000

# ── CORS — URL del frontend autorizado ───────────────────────────────────────
# En desarrollo local con Vite: http://localhost:5173
# En producción con Docker/Nginx: http://localhost (o tu dominio)
FRONTEND_URL="http://localhost:5173"
